/target

# Cargo lock (keep for binaries, omit for libraries — keep this for a binary crate)
# Cargo.lock

# Backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds
*.pdb


# HTML reports generated by sharkviz
*.html
report.html
analysis*.html
*_report.html
*_analysis.html

# Sensitive findings directories generated by capwash
sensitive/
sensitive_*/
findings/

# Redacted output pcap files
redacted*.pcap
*_redacted.pcap
*_clean.pcap
output*.pcap


# Raw captures (usually large and contain sensitive data — never commit)
*.pcap
*.pcapng
*.cap
*.dmp

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.nfs*

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains (RustRover, CLion)
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim
*.swp
*.swo
Session.vim
.netrwhist

# Emacs
*~
\#*\#
.\#*

# Environment / secrets
.env
.env.*
*.key
*.pem

# Logs
*.log
logs/